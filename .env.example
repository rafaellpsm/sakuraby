# ============================================
# SakuraBy - Configuração do Mercado Pago
# ============================================
# Copie este arquivo para .env.local

# Chave secreta para JWT (MUDE EM PRODUÇÃO!)
JWT_SECRET=coloque-uma-chave-secreta-aqui

# Mercado Pago - Passo a passo para obter:
# 1. Acesse https://www.mercadopago.com.br/developers
# 2. Crie uma conta ou faça login
# 3. Vá em "Seu negócio" > "Credenciais"
# 4. Copie o Access Token de Produção (ou Teste)
MERCADO_PAGO_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# Chave pública do Mercado Pago (opcional, para o frontend)
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=YOUR_PUBLIC_KEY

# URL base do site (na Vercel, preencha com seudominio.vercel.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
